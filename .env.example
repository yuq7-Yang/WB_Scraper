SCRAPFLY_KEY="你的 Scrapfly API Key"

# 微博账号 Cookie（用 || 分隔多个账号，每3条回复自动切换下一个）
# 单账号示例：
#   WEIBO_COOKIES="SUB=_2A25xxxx..."
# 双账号示例（推荐最少2个）：
#   WEIBO_COOKIES="SUB=_2A25xxxx...||SUB=_2A26yyyy..."
# 如何获取：Edge 登录微博 -> F12 -> Application -> Cookies -> 复制 SUB 的值
WEIBO_COOKIES=""

ENABLE_REAL_REPLIES="false"
MAX_COMMENTS_PER_KEYWORD="2"
DEFAULT_MAX_PER_KEYWORD="2"
DEFAULT_MAX_TOTAL="20"
REPLY_DELAY=7
